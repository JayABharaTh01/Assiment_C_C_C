# ==========================================================
# PROJECT SETTINGS
# ==========================================================
PROJECT_NAME=Customer Complaint Chatbot
ENVIRONMENT=development
DEBUG=True

# ==========================================================
# DATA SETTINGS
# ==========================================================
DATA_FOLDER=data
SUPPORTED_EXTENSIONS=.pdf,.docx,.csv,.json

# ==========================================================
# CHUNKING SETTINGS
# ==========================================================
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ==========================================================
# EMBEDDING MODEL
# ==========================================================
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Alternatives:
# sentence-transformers/all-mpnet-base-v2
# BAAI/bge-small-en-v1.5
# intfloat/e5-base-v2

# ==========================================================
# LLM SETTINGS
# ==========================================================
LLM_PROVIDER=huggingface
LLM_MODEL=google/flan-t5-base

# Examples:
# mistralai/Mistral-7B-Instruct-v0.3
# meta-llama/Llama-3.1-8B-Instruct
# google/gemma-2-2b-it

# ==========================================================
# HUGGING FACE
# ==========================================================
HUGGINGFACE_API_KEY=your_huggingface_api_key

# ==========================================================
# OPENAI
# ==========================================================
OPENAI_API_KEY=your_openai_api_key

# ==========================================================
# PINECONE
# ==========================================================
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_ENV=your_environment
PINECONE_INDEX=customer-complaints

# ==========================================================
# CHROMADB
# ==========================================================
CHROMA_DB_PATH=./vector_db/chroma

# ==========================================================
# FAISS
# ==========================================================
FAISS_INDEX_PATH=./vector_db/faiss/faiss.index

# ==========================================================
# RETRIEVAL SETTINGS
# ==========================================================
TOP_K=5
SIMILARITY_SEARCH=cosine

# ==========================================================
# STREAMLIT
# ==========================================================
STREAMLIT_PORT=8501

# ==========================================================
# LOGGING
# ==========================================================
LOG_LEVEL=INFO
LOG_FILE=logs/chatbot.log