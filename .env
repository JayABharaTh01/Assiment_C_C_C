# ==========================================================
# PROJECT SETTINGS
# ==========================================================
PROJECT_NAME=Customer Complaint Chatbot
ENVIRONMENT=development
DEBUG=True

# ==========================================================
# DATA SETTINGS
# ==========================================================
DATA_FOLDER=data
SUPPORTED_EXTENSIONS=.pdf,.csv,.json,.docx

# ==========================================================
# CHUNKING SETTINGS
# ==========================================================
CHUNK_SIZE=500
CHUNK_OVERLAP=50
CHUNK_STRATEGY=recursive

# ==========================================================
# EMBEDDING SETTINGS
# ==========================================================
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32
NORMALIZE_EMBEDDINGS=True
EMBEDDING_PROVIDER=sentence-transformers

# ==========================================================
# OPENAI LLM SETTINGS
# ==========================================================
OPENAI_API_KEY=REDACTED_REPLACE_WITH_YOUR_KEY

OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_TOKENS=512

# ==========================================================
# PINECONE SETTINGS
# ==========================================================
PINECONE_API_KEY=pcsk_3TiytZ_N3GbfHCNpy9XzWbKYBKUZVJH5TN6fi5Y1SUz7pUuG5DViE6rhRZiDTF6tUqq1eb
PINECONE_INDEX=customer-complaints
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# ==========================================================
# RETRIEVAL SETTINGS
# ==========================================================
TOP_K=5
SIMILARITY_SEARCH=cosine

# ==========================================================
# STREAMLIT
# ==========================================================
STREAMLIT_PORT=8501

# ==========================================================
# LOGGING
# ==========================================================
LOG_LEVEL=INFO

# ==========================================================
# CACHE
# ==========================================================
ENABLE_CACHE=True
CACHE_FOLDER=cache

# ==========================================================
# RANDOM SEED
# ==========================================================
RANDOM_SEED=42

