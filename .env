# ==========================================================
# PROJECT SETTINGS
# ==========================================================
PROJECT_NAME=Customer Complaint Chatbot
ENVIRONMENT=development
DEBUG=True

# ==========================================================
# DATA SETTINGS
# ==========================================================
DATA_FOLDER=data
SUPPORTED_EXTENSIONS=.pdf,.docx,.csv,.json

# ==========================================================
# CHUNKING SETTINGS
# ==========================================================
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ==========================================================
# EMBEDDING MODEL
# ==========================================================
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32
NORMALIZE_EMBEDDINGS=True

# ==========================================================
# LLM SETTINGS (Removed - HuggingFace support removed)
# ==========================================================

# ==========================================================
# OPENAI
# ==========================================================
OPENAI_API_KEY=your_openai_api_key_here

# ==========================================================
# PINECONE
# ==========================================================
PINECONE_API_KEY=pcsk_3TiytZ_N3GbfHCNpy9XzWbKYBKUZVJH5TN6fi5Y1SUz7pUuG5DViE6rhRZiDTF6tUqq1eb
PINECONE_INDEX=customer-complaints
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# ==========================================================
# CHROMADB
# ==========================================================
CHROMA_DB_PATH=./vector_db/chroma

# ==========================================================
# FAISS
# ==========================================================
FAISS_INDEX_PATH=./vector_db/faiss/faiss.index

# ==========================================================
# RETRIEVAL SETTINGS
# ==========================================================
TOP_K=5
SIMILARITY_SEARCH=cosine
RERANK=False

# ==========================================================
# STREAMLIT
# ==========================================================
STREAMLIT_PORT=8501
STREAMLIT_THEME=light
# ==========================================================
# LOGGING
# ==========================================================
LOG_LEVEL=INFO
LOG_FILE=logs/chatbot.log
LOG_CONSOLE=True

#===========================================================
CHUNK_SIZE=500
CHUNK_OVERLAP=50
CHUNK_STRATEGY=recursive
#===========================================================
RANDOM_SEED=42
#===========================================================
ENABLE_CACHE=True
CACHE_FOLDER=cache
#===========================================================
VECTOR_DB=chromadb